{
  "name": "techfest",
  "version": "2.0.0",
  "private": true,
  "description": "TechFest full-stack app (React + Express + MongoDB)",
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
