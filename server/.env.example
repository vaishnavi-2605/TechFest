PORT=5000
NODE_ENV=development
DB_MODE=atlas
MONGODB_URI=<your-atlas-uri>
LOCAL_MONGODB_URI=
CLIENT_ORIGIN=http://localhost:5173,http://localhost:8080,http://localhost:8081,http://localhost:8082
PUBLIC_API_BASE_URL=http://localhost:5005
JWT_SECRET=<your-strong-jwt-secret>
ADMIN_NAME=<admin-name>
ADMIN_EMAIL=<admin-email>
ADMIN_USERNAME=<admin-username>
ADMIN_PASSWORD=<admin-password>
ENABLE_EVENT_SEED=false
SIGNATURE_EVENT_COORDINATOR_EMAIL=<signature-coordinator-email>
SIGNATURE_EVENT_COORDINATOR_PASSWORD=<signature-coordinator-password>
SIGNATURE_EVENT_COORDINATOR_NAME=<signature-coordinator-name>
SIGNATURE_EVENT_COORDINATOR_DEPARTMENT=General
SIGNATURE_EVENT_TITLE=Project Competition
